---
import '../styles/global.css';
import SyncBanner from '../components/SyncBanner.astro';
import MobileNav from '../components/MobileNav.astro';

interface Props {
  title?: string;
  description?: string;
}

const { title = 'StickerSync 2026', description = 'Tracker del álbum Panini Mundial 2026' } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="default" />
    <meta name="theme-color" content="#4a00b7" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Anton&family=Noto+Sans:wght@400;500;700&family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="flex min-h-screen flex-col bg-background pb-mobile-nav text-on-background md:pb-0">
    <SyncBanner />
    <slot />
    <MobileNav />
    <script src="../scripts/tracker.ts"></script>
  </body>
</html>
