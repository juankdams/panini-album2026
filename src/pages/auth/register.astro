---
import AppLayout from '../../layouts/AppLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---

<AppLayout title="Registro | StickerSync 2026">
  <Header />
  <main class="mx-auto w-full max-w-md flex-grow px-section py-10">
    <h1 class="font-anton mb-2 text-3xl uppercase text-on-surface">Crear cuenta</h1>
    <p class="mb-8 text-on-surface-variant">
      Tu progreso local se migrará automáticamente al registrarte.
    </p>

    <form data-auth-form="register" class="space-y-4 border-4 border-on-surface bg-surface-container-lowest p-6">
      <div>
        <label for="email" class="mb-1 block text-xs font-bold uppercase">Email</label>
        <input
          id="email"
          name="email"
          type="email"
          required
          autocomplete="email"
          class="w-full border-4 border-outline-variant bg-white px-4 py-3 text-sm focus:border-primary focus:outline-none"
        />
      </div>
      <div>
        <label for="password" class="mb-1 block text-xs font-bold uppercase">Contraseña</label>
        <input
          id="password"
          name="password"
          type="password"
          required
          minlength="6"
          autocomplete="new-password"
          class="w-full border-4 border-outline-variant bg-white px-4 py-3 text-sm focus:border-primary focus:outline-none"
        />
        <p class="mt-1 text-[10px] text-on-surface-variant">Mínimo 6 caracteres</p>
      </div>
      <p data-auth-error class="hidden text-sm font-bold text-error" role="alert"></p>
      <button
        type="submit"
        class="w-full bg-primary py-3 font-anton text-sm uppercase text-on-primary high-contrast-border hover:bg-primary-container"
      >
        Registrarse
      </button>
    </form>

    <p class="mt-6 text-center text-sm text-on-surface-variant">
      ¿Ya tienes cuenta?
      <a href="/auth/login" class="font-bold text-primary hover:underline">Inicia sesión</a>
    </p>
  </main>
  <Footer />
  <script src="../../scripts/auth.ts"></script>
</AppLayout>
